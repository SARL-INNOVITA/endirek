# ══════════════════════════════════════════════════════════════
# ENDIREK API — variables d'environnement (exemple)
# Copier vers .env et ajuster. Ne JAMAIS committer de vraies clés.
# ══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
NODE_ENV=development
# 3001 (et non 3000) : le port 3000 est souvent occupé par d'autres
# projets de dev sur la machine locale.
PORT=3001
API_PUBLIC_URL=http://localhost:3001
# Origines explicites autorisées. En NODE_ENV=development, l'API ajoute aussi
# automatiquement http://localhost:<port> et http://127.0.0.1:<port> pour
# Flutter Web et les serveurs locaux à port dynamique. En production, seules
# les origines listées ici sont autorisées.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# ── Base de données (cible : PostgreSQL/PostGIS) ───────────────
# Deux drivers au comportement OBSERVABLE identique :
#   - mock (défaut)  : base en mémoire, aucune infra requise — idéal dev API.
#   - postgres       : repositories SQL au-dessus du conteneur Docker PostGIS.
# DB_DRIVER=postgres NÉCESSITE :
#   1. le conteneur Docker endirek-postgres lancé (voir infra/docker-compose) ;
#   2. les migrations appliquées : `npm run db:migrate --workspace apps/api`
#      (crée les 13 tables + insère post_types/reaction_types).
# Le choix du driver est lu au CHARGEMENT du module (décision de bootstrap
# d'infra) : en mode postgres, la couche mock n'est même pas instanciée.
DB_DRIVER=mock
# Charger le seed de démonstration La Réunion au démarrage (utilisateurs, posts,
# caméras...). Gouverne les DEUX drivers :
#   - mock     : seed chargé en mémoire à chaque boot ;
#   - postgres : seed inséré SI la table users est VIDE (idempotent, atomique) ;
#                base déjà seedée = aucun re-seed. Utiliser `npm run db:reset`
#                pour vider les données et forcer un re-seed au prochain boot.
# false = base vide (mock) / pas de seed automatique (postgres).
DB_MOCK_SEED=true
# URL de connexion complète (PRIORITAIRE sur les champs POSTGRES_* individuels).
DATABASE_URL=postgresql://endirek:endirek@localhost:5432/endirek
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=endirek
POSTGRES_USER=endirek
POSTGRES_PASSWORD=endirek

# ── Auth / JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ── OAuth social (non configuré — placeholders, ne pas bloquer) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=

# ── Stockage médias (adapter : local en dev, s3 pour Hetzner) ──
# Lot 1 : IMAGES UNIQUEMENT (JPEG, PNG, WebP), validées par décodage réel
# côté serveur — les vidéos arriveront dans un lot ultérieur.
# Driver 'local' : fichiers écrits dans UPLOAD_DIR (chemin relatif résolu
# depuis apps/api) et servis publiquement sur /uploads/.
# Driver 's3' : NON implémenté au Lot 1 (le démarrage échoue explicitement).
MEDIA_STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
# Taille maximale d'un fichier uploadé, en mégaoctets (défaut : 8).
MEDIA_MAX_FILE_SIZE_MB=8
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── Cartographie / géocodage ───────────────────────────────────
MAP_PROVIDER=osm
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_API_KEY=
GEOCODING_PROVIDER=mock
GEOCODING_API_KEY=

# ── Notifications push (mock tant que Firebase/APNs absents) ───
PUSH_DRIVER=mock
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FCM_SERVER_KEY=

# ── Email transactionnel (mock tant que Brevo absent) ──────────
EMAIL_DRIVER=mock
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Endirek
