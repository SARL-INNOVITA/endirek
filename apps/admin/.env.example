# Variables d'environnement du backoffice Endirek (préfixe VITE_ obligatoire
# pour être exposées au navigateur — n'y mettre AUCUN secret).
# Copier ce fichier en `.env` puis adapter les valeurs à votre environnement.

# URL de base de l'API Endirek (sans slash final).
VITE_API_URL=http://localhost:3001
